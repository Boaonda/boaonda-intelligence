# Copie este arquivo para .env e ajuste os valores
# No Railway: configure essas variáveis no painel "Variables"

# Chave secreta para sessões Flask (gere uma string aleatória longa)
SECRET_KEY=troque-por-uma-chave-longa-e-aleatoria

# Credenciais de acesso ao portal
AUTH_USERNAME=admin
AUTH_PASSWORD=troque-por-senha-forte

# Conexão com o MySQL interno (só acessível na rede local — usado pelo
# processador.py ao rodar localmente para gerar os JSONs)
MYSQL_HOST=10.200.0.10
MYSQL_PORT=3306
MYSQL_USER=usuario
MYSQL_PASSWORD=senha
MYSQL_DB=nome_do_banco
